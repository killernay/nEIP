{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Fastify REST API server for nEIP",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@neip/ai": "workspace:*",
    "@neip/core": "workspace:*",
    "@neip/db": "workspace:*",
    "@neip/shared": "workspace:*",
    "@neip/tax": "workspace:*",
    "argon2": "^0.44.0",
    "drizzle-orm": "0.44.0",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "typescript": "*"
  }
}
